{
  "name": "chaosmodmain",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "compile": "bun build --compile --minify index.ts --outfile dist/ChaosModStreamerApp.exe",
    "dev": "bun index.ts",
    "debug": "bun index.ts --debug",
    "watch": "bun --watch index.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare:hub-assets": "bun scripts/prepare-hub-assets.ts",
    "dev:hub": "bun run prepare:hub-assets && bun scripts/dev-hub.ts",
    "build:hub": "bun run prepare:hub-assets && bun scripts/clean-hub-dist.ts && bun build --target=browser --minify --define:process.env.NODE_ENV='\"production\"' frontend/hub/index.html --outdir=dist-hub && bun scripts/copy-hub-assets-to-dist.ts"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tanstack/react-query-devtools": "^5.100.10",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.5.0",
    "typescript-eslint": "^8.59.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.1",
    "@tanstack/eslint-plugin-query": "^5.100.10",
    "@tanstack/react-query": "^5.100.10",
    "@tanstack/react-router": "^1.170.4",
    "colors": "^1.4.0",
    "exceljs": "^4.4.0",
    "lucide-react": "^1.14.0",
    "open": "^11.0.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  }
}