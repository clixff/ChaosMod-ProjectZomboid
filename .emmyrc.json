{
  "$schema": "https://raw.githubusercontent.com/EmmyLuaLs/emmylua-analyzer-rust/refs/heads/main/crates/emmylua_code_analysis/resources/schema.json",
  "diagnostics": {
    "disable": [
      "unnecessary-if",
      "invert-if",
      "unused"
    ]
  },
  "runtime": {
    "requirePattern": [
      "shared/?.lua",
      "client/?.lua",
      "server/?.lua"
    ],
    "version": "Lua5.1"
  },
  "workspace": {
    "library": [
      "$PZ_UMBRELLA"
    ],
    "workspaceRoots": [
      "Contents/mods/ChaosMod/42/media/lua"
    ],
    "ignoreDir": [
      "releases",
      "Contents/mods/ChaosMod/42/media/lua/client/ChaosMod/thirdparty"
    ]
  }
}